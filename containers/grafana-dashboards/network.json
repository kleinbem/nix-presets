{
  "title": "Network / Routers",
  "uid": "network-routers",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Hosts up",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ] } },
      "targets": [ { "expr": "up{job=\"node-exporters\"}", "legendFormat": "{{instance}}", "refId": "A" } ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU load (1m)",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [ { "expr": "node_load1", "legendFormat": "{{instance}}", "refId": "A" } ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Temperature (°C)",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": { "defaults": { "unit": "celsius" } },
      "targets": [ { "expr": "node_hwmon_temp_celsius", "legendFormat": "{{instance}} {{sensor}}", "refId": "A" } ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Network throughput (bytes/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device!~\"lo|br-.*\"}[5m])", "legendFormat": "rx {{instance}} {{device}}", "refId": "A" },
        { "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|br-.*\"}[5m])", "legendFormat": "tx {{instance}} {{device}}", "refId": "B" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Memory available (bytes)",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [ { "expr": "node_memory_MemAvailable_bytes", "legendFormat": "{{instance}}", "refId": "A" } ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Conntrack usage (%)",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 } },
      "targets": [ { "expr": "node_nf_conntrack_entries / node_nf_conntrack_entries_limit * 100", "legendFormat": "{{instance}}", "refId": "A" } ]
    }
  ]
}
