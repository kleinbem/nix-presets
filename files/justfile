# System Control Center — personal/OS operations.
#
# Invoked as `os <namespace>::<recipe>` via the shell alias. Workspace
# concerns (dev, deployment, jj) live in the meta-workspace justfile at
# ~/Develop/github.com/kleinbem/nix.
#
# Recipes are organised into namespaces; modules live in ~/.just/.

mod ai      '.just/ai.just'
mod cleanup '.just/cleanup.just'
mod diag    '.just/diag.just'
mod dx      '.just/dx.just'
mod fix     '.just/fix.just'
mod logs    '.just/logs.just'
mod notes   '.just/notes.just'
mod service '.just/service.just'
mod system  '.just/system.just'

# List all available recipes (including namespaced ones).
default:
    @just --list --justfile ~/.justfile

# `os rebuild` — top-level shortcut for the most-frequent operation.
rebuild:
    @just system::rebuild
